@page "/admin/gallery/new"
@attribute [Authorize]
@inject SupabaseClient Supabase
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>New Gallery Item — Admin</PageTitle>

<section class="section section-narrow">
    <div class="container">
        <span class="eyebrow">Admin</span>
        <h1 class="section-title">New Gallery Item</h1>

        @if (_error is not null)
        {
            <p class="field-error">@_error</p>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="title">Title</label>
                <InputText id="title" class="form-control" @bind-Value="_model.Title" />
            </div>

            <div class="form-group">
                <label for="event">Event</label>
                <InputSelect id="event" class="form-control" @bind-Value="_model.EventName">
                    <option value="">Select an event</option>
                    @foreach (var evt in _events)
                    {
                        <option value="@evt.Title">@evt.Title</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group">
                <label>Media Type</label>
                <div class="flex gap-2">
                    <label><input type="radio" name="mediaType" checked="@(_mediaType == GalleryMediaType.Photo)" @onchange="@(() => { _mediaType = GalleryMediaType.Photo; })" /> Photo</label>
                    <label><input type="radio" name="mediaType" checked="@(_mediaType == GalleryMediaType.Video)" @onchange="@(() => { _mediaType = GalleryMediaType.Video; })" /> Video</label>
                </div>
            </div>

            @if (_mediaType == GalleryMediaType.Photo)
            {
                <div class="form-group">
                    <label for="photo">Photo</label>
                    <InputFile id="photo" OnChange="HandleFileSelected" accept="image/*" />
                    @if (_uploading)
                    {
                        <small>Uploading...</small>
                    }
                    @if (!string.IsNullOrWhiteSpace(_model.ImageUrl))
                    {
                        <small>Uploaded ✓</small>
                    }
                </div>
            }
            else
            {
                <div class="form-group">
                    <label for="videolink">Video Link</label>
                    <InputText id="videolink" class="form-control" @bind-Value="_videoUrlInput" placeholder="@_videoPlaceholder" />
                    <div class="flex gap-1" style="margin-top:0.4rem">
                        <button type="button" class="btn btn-outline btn-sm" @onclick="OpenLinkToResolve">
                            Open link in a new tab
                        </button>
                    </div>
                    <small>
                        Works with TikTok and YouTube links — just paste them in. Got a shortened link (like
                        vt.tiktok.com or youtu.be)? Paste it above, click "Open link in a new tab", then copy the
                        full address from the tab that opens and paste that back in here before saving. Other video
                        sites may work too if you paste a direct embed link.
                    </small>
                </div>
            }

            <div class="flex gap-1">
                <button type="submit" class="btn btn-primary" disabled="@_uploading">Save</button>
                <a href="/admin" class="btn btn-outline">Cancel</a>
            </div>
        </EditForm>
    </div>
</section>

@code {
    private GalleryItem _model = new();
    private GalleryMediaType _mediaType = GalleryMediaType.Photo;
    private string _videoUrlInput = "";
    private List<EventItem> _events = new();
    private bool _uploading;
    private string? _error;
    private readonly string _videoPlaceholder = "https://www.tiktok.com/@dez.reunion/video/... or a YouTube link";

    protected override async Task OnInitializedAsync()
    {
        _events = await Supabase.GetAllEventsAsync();
    }

    private async Task OpenLinkToResolve()
    {
        if (string.IsNullOrWhiteSpace(_videoUrlInput))
        {
            _error = "Paste a video link first.";
            return;
        }

        await JS.InvokeVoidAsync("open", _videoUrlInput.Trim(), "_blank");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _uploading = true;
        try
        {
            var file = e.File;
            await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _model.ImageUrl = await Supabase.UploadImageAsync(stream, file.Name, file.ContentType);
        }
        catch (Exception ex)
        {
            _error = $"Photo upload failed: {ex.Message}";
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task HandleSubmit()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_model.EventName))
        {
            _error = "Please select an event.";
            return;
        }

        _model.Type = _mediaType;

        if (_mediaType == GalleryMediaType.Video)
        {
            var parsed = SupabaseClient.ParseVideoLink(_videoUrlInput);
            if (parsed is null)
            {
                _error = "That doesn't look like a valid video link — please check and try again.";
                return;
            }

            _model.VideoUrl = parsed.EmbedUrl;
            _model.TikTokVideoId = parsed.TikTokVideoId;
        }
        else if (string.IsNullOrWhiteSpace(_model.ImageUrl))
        {
            _error = "Please upload a photo.";
            return;
        }

        await Supabase.AddGalleryItemAsync(_model);
        Navigation.NavigateTo("/admin");
    }
}
